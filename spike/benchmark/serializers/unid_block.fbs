/* C++ Structure */
struct Unid_block {
  uint32_t ip;
  uint16_t port;
  uint32_t seq;
  uint32_t node;
  uint64_t first_unid;
  uint32_t block_size;
}

/* Flatbuffers table */
table Unid_block_t {
  ip:uint;
  port:ushort;
  seq:uint;
  node:uint;
  first_unid:ulong;
  block_size:uint;
}

root_type Unid_block_t;
